# JWT_OIDC_WELL_KNOWN_CONFIG=
# JWT_OIDC_CLIENT_SECRET=
# JWT_OIDC_AUDIENCE=

# Keycloak configuration
KEYCLOAK_BASE_URL=
KEYCLOAK_REALMNAME=

# CORS Configuration
CORS_ORIGIN=http://localhost:5000

# S3 Configuration
S3_ACCESS_KEY_ID=
S3_BUCKET="engagement-dev-uploads"
