FLASK_ENV=development
ENV=development
TESTING=false
DEBUG=true

# Database Configuration
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_URL=

EMAIL_PROVIDER="GC_NOTIFY"

# GC Notify
GC_NOTIFY_API_BASE_URL=
GC_NOTIFY_API_KEY=
GC_NOTIFY_EMAIL_TEMPLATE_ID=

# CHES Configuration
CHES_EMAIL_FROM_ID="modernengagement@gov.bc.ca"
CHES_POST_EMAIL_ENDPOINT=
CHES_SSO_CLIENT_ID=
CHES_SSO_CLIENT_SECRET=
CHES_SSO_TOKEN_URL=

# JWT OIDC Configuration
JWT_OIDC_ISSUER=
JWT_OIDC_JWKS_URI=
JWT_OIDC_ALGORITHMS=RS256
JWT_OIDC_CACHING_ENABLED=true
JWT_OIDC_JWKS_CACHE_TIMEOUT=300
